{
  // Ejemplo de configuración de VSCode para el proyecto
  // Renombrar a settings.json para usar
  
  // Python
  "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "python.formatting.provider": "autopep8",
  
  // Editor
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  
  // Files
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/venv": true,
    "**/node_modules": true,
    "**/dist": true,
    "data/processed": true,
    "data/exports": true
  },
  
  // Search
  "search.exclude": {
    "**/venv": true,
    "**/node_modules": true,
    "**/dist": true,
    "data/processed": true,
    "data/exports": true,
    "**/__pycache__": true
  }
}
