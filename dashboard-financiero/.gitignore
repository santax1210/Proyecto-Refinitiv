# =============================================================================
# .gitignore Dashboard Financiero (Frontend React + Vite)
# =============================================================================

# ============= Dependencies =============
node_modules

# ============= Build Output =============
dist
dist-ssr
*.local

# ============= Logs =============
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============= Environment Variables =============
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============= Editor =============
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains IDEs
.idea
*.iml

# ============= OS Files =============
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============= Testing =============
coverage/
.nyc_output/

# ============= Temporary Files =============
*.tmp
*.temp
.cache/
