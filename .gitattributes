# Git attributes for consistent line endings across platforms
# Prevents issues with CRLF (Windows) vs LF (Linux/Mac)

# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# PowerShell scripts
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Data files (preserve as-is)
*.csv text eol=lf
*.tsv text eol=lf
*.txt text eol=lf

# Binary files (do not modify)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.xlsx binary
*.xls binary
*.zip binary
*.tar.gz binary
*.db binary
*.sqlite binary
*.pyc binary
*.pyo binary
*.so binary
*.dll binary
*.exe binary

# Exclude from exports
*.log export-ignore
.gitignore export-ignore
.gitattributes export-ignore
